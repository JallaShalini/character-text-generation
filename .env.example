# Data paths
DATASET_PATH=input/shakespeare.txt
ENCODED_DATA_PATH=data/encoded_data.pt
VOCAB_PATH=data/vocab.json
MAPPINGS_PATH=data/mappings.json

# Output paths
MODELS_DIR=models
RESULTS_DIR=results

# Training hyperparameters
LEARNING_RATE=0.001
EPOCHS=10
BATCH_SIZE=64
SEQ_LENGTH=100
EMBEDDING_DIM=128
HIDDEN_DIM=256
NUM_LAYERS=2
DROPOUT=0.1

# Transformer settings
NUM_HEADS=4
FFN_DIM=512
NUM_TRANSFORMER_LAYERS=2

# Generation settings
SEED_TEXT=To be or not to be
GENERATION_LENGTH=300
TEMPERATURE=1.0
TOP_K=0
TOP_P=1.0
